---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "wood的个人主页" } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <a href="/">首页</a>
      <a href="/blog">博客</a>
      <a href="/java">Java</a>
      <a href="/go">Go</a>
      <a href="/travel">旅行</a>
      <a href="/read">阅读</a>
      <a href="/idea">想法</a>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>© 2024 wood的个人主页</p>
    </footer>
  </body>
</html>

<style>
  nav {
    padding: 1rem;
    background: #f8f9fa;
    display: flex;
    gap: 1rem;
    justify-content: center;
  }
  nav a {
    text-decoration: none;
    color: #333;
    padding: 0.5rem 1rem;
    border-radius: 4px;
  }
  nav a:hover {
    background: #e9ecef;
  }
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }
  footer {
    text-align: center;
    padding: 2rem;
    color: #666;
  }
</style>