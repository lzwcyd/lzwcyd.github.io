---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await Promise.all([
  getCollection('java'),
  getCollection('go'),
  getCollection('travel'),
  getCollection('read'),
  getCollection('idea'),
]);

const posts = allPosts.flat().sort((a, b) => 
  b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="所有文章">
  <h1>所有文章</h1>
  <ul>
    {posts.map((post) => (
      <li>
        <a href={`/${post.collection}/${post.slug}`}>
          {post.data.title}
        </a>
        <span class="category">[{post.collection}]</span>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  ul {
    list-style: none;
    padding: 0;
  }
  li {
    margin: 1rem 0;
    padding: 0.5rem;
    border-bottom: 1px solid #eee;
  }
  a {
    color: #0066cc;
    text-decoration: none;
    font-weight: bold;
  }
  a:hover {
    text-decoration: underline;
  }
  .category {
    color: #666;
    font-size: 0.9rem;
    margin-left: 0.5rem;
  }
</style>