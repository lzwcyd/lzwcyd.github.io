---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="wood的个人主页">
  <h1>欢迎来到我的博客</h1>
  
  <section>
    <h2>📂 分类</h2>
    <ul>
      <li><a href="/java">Java 技术文章</a></li>
      <li><a href="/go">Go 语言文章</a></li>
      <li><a href="/travel">旅行记录</a></li>
      <li><a href="/read">阅读笔记</a></li>
      <li><a href="/idea">想法/观点</a></li>
    </ul>
  </section>

  <section>
    <h2>📝 最新文章</h2>
    <p>查看 <a href="/blog">所有文章</a></p>
  </section>
</BaseLayout>

<style>
  h1 {
    text-align: center;
    margin-bottom: 2rem;
  }
  section {
    margin: 2rem 0;
  }
  ul {
    list-style: none;
    padding: 0;
  }
  li {
    margin: 0.5rem 0;
  }
  a {
    color: #0066cc;
    text-decoration: none;
  }
  a:hover {
    text-decoration: underline;
  }
</style>